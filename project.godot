; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="前端群侠传"
config/version="0.7.9"
run/main_scene="res://scenes/splash.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="FrontendLegends"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0.00784314, 0.0235294, 0.0509804, 1)
boot_splash/image="res://icons/splash/frontend-legends-boot-splash.png"
config/icon="res://icons/frontend-legends.svg"

[autoload]

DataRegistry="*res://scripts/data_registry.gd"
SkillSystem="*res://scripts/skill_system.gd"
GameState="*res://scripts/game_state.gd"
InventorySystem="*res://scripts/inventory_system.gd"
QuestSystem="*res://scripts/quest_system.gd"
NpcSystem="*res://scripts/npc_system.gd"
CombatSystem="*res://scripts/combat_system.gd"
BattleResolve="*res://scripts/battle_resolve.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="canvas_items"
window/handheld/orientation=4

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
